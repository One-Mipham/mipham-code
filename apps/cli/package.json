{
  "name": "@miphamai/cli",
  "version": "0.3.0",
  "description": "Mipham Code — Multi-model open-core intelligent coding terminal by MiphamAI",
  "keywords": [
    "ai",
    "coding",
    "terminal",
    "cli",
    "claude",
    "openai",
    "deepseek",
    "mcp",
    "mipham",
    "agent",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/One-Mipham/mipham-code"
  },
  "homepage": "https://mipham.ai/code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mipham": "bin/mipham"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "assets/",
    "dist/"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "bun run bin/mipham.ts",
    "build": "bun build --compile --minify --external react-devtools-core ./bin/mipham.ts --outfile dist/mipham",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0",
    "react-devtools-core": "^4.19.1",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@mipham/shared": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "vitest": "^4.1.7"
  }
}
